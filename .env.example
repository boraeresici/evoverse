EVOVERSE_ENV=local
EVOVERSE_PERSISTENCE=postgres
EVOVERSE_DATABASE_URL=postgresql+psycopg://evoverse:evoverse@localhost:5433/evoverse
EVOVERSE_SEED=4211
EVOVERSE_BOOT_TICKS=96
EVOVERSE_AUTH_PROVIDER=local
EVOVERSE_AUTH_ALLOW_LOCAL_FALLBACK=true
EVOVERSE_AUTH_TRUSTED_HEADER_SECRET=
EVOVERSE_AUTH_BOOTSTRAP_ADMINS=local-admin
EVOVERSE_AUTH_BOOTSTRAP_CATALYSTS=local-catalyst
EVOVERSE_GOOGLE_CLIENT_ID=
EVOVERSE_GOOGLE_CLIENT_SECRET=
EVOVERSE_GOOGLE_REDIRECT_URI=
EVOVERSE_API_REFRESH_ON_READ=true
EVOVERSE_WORKER_INTERVAL_SECONDS=2
EVOVERSE_WORKER_TICKS_PER_STEP=1
# The scale-free scan behind /science. It replays every lattice size under every seed,
# so its cost is sizes x seeds x ticks and it runs on the worker, never in a request.
# 0 for SCAN_EVERY_STEPS disables it and leaves the last parked row in place.
# SCAN_TICKS is the depth each replayed world is advanced to -- not Alpha's age. Alpha
# is stationary from ~tick 250, so a deeper replay costs more and measures the same
# thing. SCAN_SEEDS is the ensemble: the trend of reach against size moves by ~0.09
# between seeds, so a single seed cannot tell a flat trend from a flocking one.
EVOVERSE_WORKER_SCAN_EVERY_STEPS=3600
EVOVERSE_WORKER_SCAN_TICKS=2000
EVOVERSE_WORKER_SCAN_SEEDS=8
# Operations. These default to false outside EVOVERSE_ENV=local.
# Allow destructive seed reset (POST /admin/simulation/reset -> 403 when false).
EVOVERSE_ALLOW_DESTRUCTIVE_OPS=true
# Allow the local fallback identity to hold the admin role. Set false to lock the
# admin surface (e.g. a public demo): /admin/config is gated and all admin writes
# return 403, while observer/catalyst still work in local fallback.
EVOVERSE_ALLOW_LOCAL_ADMIN=true
# Comma-separated origins allowed to call the API directly from a browser.
# BFF routes are same-origin and do not need this; only widen it if the browser
# talks to the API cross-origin.
EVOVERSE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Worker heartbeat is reported stale in health once older than this many seconds.
EVOVERSE_WORKER_STALE_SECONDS=30
# Server-only backend origin for frontend BFF routes (app/api/*).
# Falls back to NEXT_PUBLIC_API_URL when unset; set to keep backend origin off the browser.
EVOVERSE_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_PROVIDER=local
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# SEO / analytics (browser-inlined at build time). Leave blank to disable.
# Canonical + OpenGraph base URL; drives sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=https://evoverse.studiobinary.co
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX.
NEXT_PUBLIC_GA_ID=
# Cloudflare Web Analytics site token (from the CF dashboard beacon snippet).
NEXT_PUBLIC_CF_BEACON_TOKEN=
