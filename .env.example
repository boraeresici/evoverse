EVOVERSE_ENV=local
EVOVERSE_PERSISTENCE=postgres
EVOVERSE_DATABASE_URL=postgresql+psycopg://evoverse:evoverse@localhost:5433/evoverse
EVOVERSE_SEED=4211
EVOVERSE_BOOT_TICKS=96
EVOVERSE_AUTH_PROVIDER=local
EVOVERSE_AUTH_ALLOW_LOCAL_FALLBACK=true
EVOVERSE_AUTH_TRUSTED_HEADER_SECRET=
EVOVERSE_AUTH_BOOTSTRAP_ADMINS=local-admin
EVOVERSE_AUTH_BOOTSTRAP_CATALYSTS=local-catalyst
EVOVERSE_GOOGLE_CLIENT_ID=
EVOVERSE_GOOGLE_CLIENT_SECRET=
EVOVERSE_GOOGLE_REDIRECT_URI=
EVOVERSE_API_REFRESH_ON_READ=true
EVOVERSE_WORKER_INTERVAL_SECONDS=2
EVOVERSE_WORKER_TICKS_PER_STEP=1
# Operations (Paket 17). Both default to false outside EVOVERSE_ENV=local.
# Allow destructive seed reset (POST /admin/simulation/reset -> 403 when false).
EVOVERSE_ALLOW_DESTRUCTIVE_OPS=true
# Worker heartbeat is reported stale in health once older than this many seconds.
EVOVERSE_WORKER_STALE_SECONDS=30
# Server-only backend origin for frontend BFF routes (app/api/*).
# Falls back to NEXT_PUBLIC_API_URL when unset; set to keep backend origin off the browser.
EVOVERSE_API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_PROVIDER=local
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
